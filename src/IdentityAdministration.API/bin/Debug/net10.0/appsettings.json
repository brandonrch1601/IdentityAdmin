{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "IdentityAdministration": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=<server>;Port=5432;Database=<DB_NAME>;Username=<username>;Password=<password>;Include Error Detail=true"
  },
  "AzureKeyVault": {
    "VaultUri": "https://<vault-name>.vault.azure.net/",
    "TokenSigningKeyName": "<token-signing-key-name>"
  },
  "Jwt": {
    "Issuer": "<URL_ISSUER>",
    "Audience": "<audience>",
    "ExpirationMinutes": 60
  }
}
